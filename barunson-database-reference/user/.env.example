# MSSQL 접속 정보 (XERP, bar_shop1)
DB_SERVER=barun-shopdb.xxxxx.database.windows.net
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_DATABASE=bar_shop1

# DD wedding (MySQL)
# DD_DB_SERVER=
# DD_DB_PORT=3306
# DD_DB_USER=
# DD_DB_PASSWORD=

# PostgreSQL (ERP 자체 데이터)
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=sc_erp
# PG_PASSWORD=
# PG_DATABASE=sc_erp
# PG_ADMIN_USER=          # 미설정 시 권한 prelude/DDL 보강 단계 skip (보안: 자격증명 하드코딩 금지)
# PG_ADMIN_PASSWORD=

# 마스터 관리자 계정 (서버 시작 시 자동 upsert)
# ADMIN_EMAIL=sejun.song@barunn.net
# ADMIN_USERNAME=sejun.song
# ADMIN_DISPLAY_NAME=sejun.song
# ADMIN_PASSWORD=1234     # 기본값. 운영에서는 반드시 변경

# 거래처 포털 토큰 시드 (반드시 회전 — 노출 시 거래처 토큰 위조 가능)
# PORTAL_SECRET=

# Slack 알림 메시지의 ERP 바로가기 링크
# PUBLIC_BASE_URL=https://your-erp-domain.example.com

# SMTP (메일 발송)
# SMTP_USER=               # Gmail 주소
# SMTP_PASS=               # Gmail 앱 비밀번호 (16자리)
# SMTP_FROM=               # 미설정 시 SMTP_USER 사용

# Slack Webhook (선택)
# SLACK_WEBHOOK_URL=

# Google OAuth (선택 — Google 로그인)
# GOOGLE_CLIENT_ID=
# ALLOWED_EMAIL_DOMAINS=barunn.net

# Docker 환경 (docker-compose에서 자동 설정됨)
# PORT=12026
# DATA_DIR=/app/data
# UPLOAD_DIR=/app/uploads
# ERP_EXCEL_PATH=/app/data/스마트재고현황.xls
